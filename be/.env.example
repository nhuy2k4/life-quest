# ╔══════════════════════════════════════════════════════════════════╗
# ║  LifeQuest Backend — Environment Variables Template             ║
# ║  Copy file này thành .env và điền giá trị thực                  ║
# ║  KHÔNG commit .env vào git!                                     ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=true
APP_NAME=LifeQuest API
APP_VERSION=1.0.0

# ── Database ──────────────────────────────────────────────────────────────────
# asyncpg driver — bắt buộc dùng postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://postgres:postgresql@localhost:5432/lifequest

# ── Redis ─────────────────────────────────────────────────────────────────────
# DB 0: app (auth blacklist, rate limit, cache)
# DB 1: Celery broker (dùng sau khi implement workers)
# DB 2: Celery result backend
REDIS_URL=redis://localhost:6379/0

# Recommendation logs retention. Ranking uses the recent 7-14 day window.
RECOMMENDATION_LOG_RETENTION_DAYS=90
RECOMMENDATION_LOG_CLEANUP_BATCH_SIZE=5000

# ── JWT ───────────────────────────────────────────────────────────────────────
# Tạo secret mạnh: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=REPLACE_WITH_STRONG_SECRET_KEY
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── CORS ──────────────────────────────────────────────────────────────────────
# Dev: để mặc định ["*"]
# Production: CORS_ORIGINS=["https://admin.lifequest.app","exp://your-expo-url"]
# CORS_ORIGINS=["*"]

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Google Vision ─────────────────────────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=path/to/your/google-vision-key.json

# ── SMTP / Email OTP ──────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@lifequest.local
SMTP_USE_TLS=true
EMAIL_SENDING_ENABLED=true

# Push Notifications
PUSH_NOTIFICATIONS_ENABLED=true
EXPO_PUSH_ENDPOINT=https://exp.host/--/api/v2/push/send
# Optional direct FCM v1 for Android native device tokens.
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_FILE=

# ── Testing ───────────────────────────────────────────────────────────────
TESTING=false
